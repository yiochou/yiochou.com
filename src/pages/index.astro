---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { execSync } from 'node:child_process';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const now = await getEntry('pages', 'now');
if (!now) throw new Error('missing src/content/pages/now.md');
const { Content: NowContent } = await render(now);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

let nowUpdated = new Date();
try {
  const iso = execSync('git log -1 --format=%cI -- src/content/pages/now.md', {
    encoding: 'utf-8',
  }).trim();
  if (iso) nowUpdated = new Date(iso);
} catch {
  // no git history available at build time; fall back to build date
}
---
<BaseLayout
  title="Yio Chou"
  description="Tech by day, inner seeker by soul. Yio Chou's personal site and blog."
  showHeader={false}
  showFooter={false}
>
  <h1 class="site-title">Yio Chou<span class="cursor" aria-hidden="true"></span></h1>
  <p class="tagline">Tech by day, inner seeker by soul.</p>

  <section id="words">
    <h2 class="sec">Words</h2>
    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            <span class="date">{fmt(post.data.pubDate)}</span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty">soon.</p>
    )}
  </section>

  <section id="now">
    <h2 class="sec">Now</h2>
    <div class="now-content">
      <NowContent />
    </div>
    <p class="updated">updated {fmt(nowUpdated)}</p>
  </section>

  <section id="elsewhere">
    <h2 class="sec">Elsewhere</h2>
    <p class="links">
      <a href="https://github.com/yiochou">GitHub</a>
      <span class="sep">·</span>
      <a href="https://www.linkedin.com/in/yio-c-8956111a3/">LinkedIn</a>
      <span class="sep">·</span>
      <a href="https://www.instagram.com/yio.chou/">Instagram</a>
      <span class="sep">·</span>
      <a href="https://resume.yiochou.com/index.pdf">CV</a>
      <span class="sep">·</span>
      <a href="mailto:hi@yiochou.com">Email</a>
    </p>
  </section>
</BaseLayout>

<style>
  .site-title {
    font-size: 2.1rem;
    font-style: italic;
    font-weight: 600;
    margin: 1.5rem 0 0.25rem;
  }
  .cursor {
    display: inline-block;
    width: 0.42em;
    height: 0.72em;
    margin-left: 0.32em;
    border-radius: 3px;
    background: linear-gradient(160deg, var(--pink) 0%, var(--teal) 100%);
  }
  .tagline { color: var(--ink-2); margin: 0 0 4rem; }

  section { margin-bottom: 3.5rem; }
  .sec {
    display: inline-block;
    font-style: italic;
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--ink-2);
    margin: 0 0 0.75rem;
    padding-bottom: 0.25rem;
    background: linear-gradient(90deg, var(--pink) 0%, var(--teal) 100%) no-repeat left bottom / 100% 2.5px;
  }

  .empty { margin: 0; font-style: italic; color: var(--ink-3); }
  .post-list { list-style: none; margin: 0; padding: 0; }
  .post-list li {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.45rem 0;
  }
  .post-list a { text-decoration: none; }
  .post-list a:hover { text-decoration: underline; text-decoration-color: var(--pink-deep); }
  .date { margin-left: auto; color: var(--ink-3); font-family: var(--font-sans); font-size: 0.8rem; }

  .now-content :global(p) { margin: 0 0 0.75rem; }
  .now-content :global(ul) { margin: 0 0 0.75rem; padding-left: 1.25rem; }
  .updated { margin: 0; font-style: italic; color: var(--ink-3); font-size: 0.85rem; }

  .links {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .links a { color: var(--ink-2); text-decoration: none; }
  .links a:hover { color: var(--ink); text-decoration: underline; text-decoration-color: var(--teal-text); }
  .sep { color: var(--ink-3); margin: 0 0.35rem; }
</style>
